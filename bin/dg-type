#!/usr/bin/env python3
"""Deepgram dictation that types finalized phrases into the focused window."""

from __future__ import annotations

import argparse
import array
import importlib
import importlib.util
import json
import math
import os
import queue
import shlex
import signal
import shutil
import subprocess
import sys
import threading
import time
from dataclasses import dataclass
from pathlib import Path
from urllib.parse import urlencode

# Avoid stale/corrupt bytecode generated by a different Python build between
# host and distrobox. This makes dg-type import third-party packages from
# source for each run instead of touching the shared ~/.local __pycache__ tree.
sys.dont_write_bytecode = True
sys.pycache_prefix = f"/tmp/dg-type-pycache-{os.getuid()}-{os.getpid()}"


PIDFILE = Path(f"/tmp/dg-type-{os.getuid()}.pid")
OVERLAY_STATE_PATH = Path(f"/tmp/dg-type-overlay-{os.getuid()}.json")
OVERLAY_BIN = Path.home() / ".local" / "bin" / "dg-type-overlay"
DEFAULT_MODEL = "nova-3"
DEFAULT_LANG = "en-US"
DEFAULT_SILENCE_TIMEOUT = 7.0
_global_stop_event: threading.Event | None = None
_overlay_started = False
_last_overlay_write = 0.0


def notify(message: str, timeout_ms: int = 2500, urgency: str = "normal") -> None:
    """Show a desktop notification when notify-send is available."""
    if not shutil.which("notify-send"):
        return

    subprocess.run(
        [
            "notify-send",
            "-t",
            str(timeout_ms),
            "-u",
            urgency,
            "-h",
            "string:x-canonical-private-synchronous:dg-type",
            "-i",
            "audio-input-microphone",
            "dg-type",
            message,
        ],
        check=False,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )


def clear_notification() -> None:
    notify(" ", timeout_ms=1)


def log_event(message: str) -> None:
    if os.environ.get("DG_TYPE_LOG_EVENTS"):
        print(message, flush=True)


def overlay_event(
    args: argparse.Namespace | None,
    state: str,
    text: str = "",
    *,
    level: float | None = None,
    force: bool = True,
) -> None:
    if args is not None and getattr(args, "no_overlay", False):
        return

    global _overlay_started, _last_overlay_write
    now = time.time()
    if not force and now - _last_overlay_write < 0.05:
        return

    try:
        if not _overlay_started and OVERLAY_BIN.exists() and os.access(OVERLAY_BIN, os.X_OK):
            env = os.environ.copy()
            if env.get("DISPLAY"):
                env.setdefault("GDK_BACKEND", "x11")
            subprocess.Popen(
                [str(OVERLAY_BIN)],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                env=env,
                start_new_session=True,
            )
            _overlay_started = True

        payload = {"state": state, "text": text, "time": now}
        if level is not None:
            payload["level"] = max(0.0, min(1.0, level))
        OVERLAY_STATE_PATH.write_text(
            json.dumps(payload),
            encoding="utf-8",
        )
        _last_overlay_write = now
    except Exception as exc:
        log_event(f"Overlay event failed: {exc}")


def command_output(result: subprocess.CompletedProcess[bytes]) -> str:
    stderr = result.stderr.decode(errors="replace").strip()
    stdout = result.stdout.decode(errors="replace").strip()
    return stderr or stdout or f"exit status {result.returncode}"


def run_command(
    argv: list[str],
    *,
    input_text: str | None = None,
    timeout: float = 5.0,
) -> subprocess.CompletedProcess[bytes]:
    input_bytes = input_text.encode() if input_text is not None else None
    return subprocess.run(
        argv,
        input=input_bytes,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        check=False,
        timeout=timeout,
    )


def purge_module_bytecode(module_name: str) -> list[Path]:
    spec = importlib.util.find_spec(module_name)
    roots: list[Path] = []
    if spec and spec.submodule_search_locations:
        roots.extend(Path(path) for path in spec.submodule_search_locations)
    elif spec and spec.origin:
        roots.append(Path(spec.origin).parent)

    removed: list[Path] = []
    for root in roots:
        if not root.exists():
            continue
        for cache_dir in root.rglob("__pycache__"):
            if not cache_dir.is_dir():
                continue
            try:
                shutil.rmtree(cache_dir)
            except OSError:
                continue
            removed.append(cache_dir)
    importlib.invalidate_caches()
    return removed


def import_module_self_healing(module_name: str):
    try:
        return importlib.import_module(module_name)
    except Exception as first_exc:
        if "bad marshal data" not in str(first_exc).lower():
            raise
        removed = purge_module_bytecode(module_name.split(".", 1)[0])
        log_event(f"Removed corrupt bytecode caches: {removed}")
        return importlib.import_module(module_name)


def get_official_profile_api_key() -> str | None:
    """Read the API key from the official dg/deepctl auth manager."""
    try:
        from deepctl_core.auth import AuthManager
        from deepctl_core.config import Config
    except Exception:
        return None

    try:
        return AuthManager(Config()).get_api_key(ignore_env=True)
    except Exception:
        return None


def get_deepgram_api_key() -> tuple[str | None, str | None]:
    """Return the API key and the source used."""
    api_key = get_official_profile_api_key()
    if api_key:
        return api_key, "dg/deepctl profile"

    api_key = os.environ.get("DEEPGRAM_API_KEY")
    if api_key:
        return api_key, "DEEPGRAM_API_KEY"

    fallback_path = Path.home() / ".config" / "deepgram-api-key"
    try:
        api_key = fallback_path.read_text(encoding="utf-8").strip()
    except FileNotFoundError:
        return None, None
    except OSError:
        return None, None

    if api_key:
        return api_key, str(fallback_path)

    return None, None


@dataclass
class ProbeResult:
    ok: bool
    detail: str


class InjectorError(RuntimeError):
    pass


class Injector:
    name = ""
    binary = ""
    binary_candidates: tuple[str, ...] = ()

    def resolve_binary(self) -> str | None:
        candidates = self.binary_candidates or (self.binary,)
        for candidate in candidates:
            if "/" in candidate:
                if os.access(candidate, os.X_OK):
                    return candidate
                continue

            resolved = shutil.which(candidate)
            if resolved:
                return resolved

        return None

    def probe(self) -> ProbeResult:
        if not self.resolve_binary():
            return ProbeResult(False, f"{self.binary} not found in PATH")

        try:
            self.type_text("", timeout=3.0)
        except Exception as exc:
            return ProbeResult(False, str(exc))

        return ProbeResult(True, "ready")

    def type_text(self, text: str, *, timeout: float = 10.0) -> None:
        raise NotImplementedError

    def backspace(self, count: int, *, timeout: float = 10.0) -> None:
        raise NotImplementedError


class WtypeInjector(Injector):
    name = "wtype"
    binary = "wtype"
    binary_candidates = ("wtype", str(Path.home() / ".local" / "bin" / "wtype"))

    def type_text(self, text: str, *, timeout: float = 10.0) -> None:
        binary = self.resolve_binary()
        if not binary:
            raise InjectorError("wtype not found")

        result = run_command([binary, "-"], input_text=text, timeout=timeout)
        if result.returncode != 0:
            raise InjectorError(command_output(result))

    def backspace(self, count: int, *, timeout: float = 10.0) -> None:
        if count <= 0:
            return

        binary = self.resolve_binary()
        if not binary:
            raise InjectorError("wtype not found")

        result = run_command([binary, *["-k", "BackSpace"] * count], timeout=timeout)
        if result.returncode != 0:
            raise InjectorError(command_output(result))


class YdotoolInjector(Injector):
    name = "ydotool"
    binary = "ydotool"
    binary_candidates = ("ydotool", str(Path.home() / ".local" / "bin" / "ydotool"), "/usr/bin/ydotool")

    @staticmethod
    def socket_path() -> str:
        runtime_dir = os.environ.get("XDG_RUNTIME_DIR", f"/run/user/{os.getuid()}")
        return os.environ.get("YDOTOOL_SOCKET", f"{runtime_dir}/.ydotool_socket")

    @staticmethod
    def resolve_daemon() -> str:
        candidates = (
            "/usr/local/bin/dg-type-ydotoold",
            str(Path.home() / ".local" / "bin" / "ydotoold"),
            "/usr/local/bin/ydotoold",
            "/usr/bin/ydotoold",
        )
        for candidate in candidates:
            if os.access(candidate, os.X_OK):
                return candidate

        return str(Path.home() / ".local" / "bin" / "ydotoold")

    @staticmethod
    def daemon_argv() -> list[str]:
        return [
            YdotoolInjector.resolve_daemon(),
            f"--socket-path={YdotoolInjector.socket_path()}",
            f"--socket-own={os.getuid()}:{os.getgid()}",
            "--socket-perm=0600",
        ]

    @staticmethod
    def setup_hint() -> str:
        argv_q = " ".join(shlex.quote(part) for part in YdotoolInjector.daemon_argv())
        return (
            "ydotoold is not reachable. Start the daemon, then retry:\n"
            "  dg-type --setup-injector\n\n"
            "If auto-start is installed, inspect it with:\n"
            "  sudo systemctl status dg-type-ydotoold.service\n"
            "  journalctl -u dg-type-ydotoold.service -b --no-pager\n\n"
            "Equivalent command:\n"
            f"  sudo -b {argv_q}"
        )

    def probe(self) -> ProbeResult:
        if not self.resolve_binary():
            return ProbeResult(False, "ydotool not found in PATH or /usr/bin")

        try:
            self.type_text("", timeout=3.0)
        except Exception as exc:
            detail = str(exc)
            if "No such file or directory" in detail or "failed to connect socket" in detail:
                return ProbeResult(False, self.setup_hint())
            return ProbeResult(False, detail)

        return ProbeResult(True, "ready")

    def type_text(self, text: str, *, timeout: float = 10.0) -> None:
        binary = self.resolve_binary()
        if not binary:
            raise InjectorError("ydotool not found")

        result = run_command(
            [binary, "type", "--key-delay", "0", "--file", "-"],
            input_text=text,
            timeout=timeout,
        )
        if result.returncode != 0:
            raise InjectorError(command_output(result))

    def backspace(self, count: int, *, timeout: float = 10.0) -> None:
        if count <= 0:
            return

        binary = self.resolve_binary()
        if not binary:
            raise InjectorError("ydotool not found")

        remaining = count
        while remaining > 0:
            chunk = min(remaining, 80)
            keys = ["14:1", "14:0"] * chunk
            result = run_command(
                [binary, "key", "--key-delay", "0", *keys],
                timeout=timeout,
            )
            if result.returncode != 0:
                raise InjectorError(command_output(result))
            remaining -= chunk


class XdotoolInjector(Injector):
    name = "xdotool"
    binary = "xdotool"
    binary_candidates = ("xdotool", "/usr/bin/xdotool")

    def probe(self) -> ProbeResult:
        binary = self.resolve_binary()
        if not binary:
            return ProbeResult(False, "xdotool not found in PATH or /usr/bin")

        try:
            result = run_command([binary, "getwindowfocus"], timeout=3.0)
        except Exception as exc:
            return ProbeResult(False, str(exc))

        if result.returncode != 0:
            return ProbeResult(False, command_output(result))

        return ProbeResult(True, "ready")

    def type_text(self, text: str, *, timeout: float = 10.0) -> None:
        binary = self.resolve_binary()
        if not binary:
            raise InjectorError("xdotool not found")

        result = run_command(
            [binary, "type", "--clearmodifiers", "--delay", "0", "--", text],
            timeout=timeout,
        )
        if result.returncode != 0:
            raise InjectorError(command_output(result))

    def backspace(self, count: int, *, timeout: float = 10.0) -> None:
        if count <= 0:
            return

        binary = self.resolve_binary()
        if not binary:
            raise InjectorError("xdotool not found")

        result = run_command(
            [binary, "key", "--clearmodifiers", "--delay", "0", *["BackSpace"] * count],
            timeout=timeout,
        )
        if result.returncode != 0:
            raise InjectorError(command_output(result))


INJECTOR_CLASSES: dict[str, type[Injector]] = {
    "wtype": WtypeInjector,
    "ydotool": YdotoolInjector,
    "xdotool": XdotoolInjector,
}
AUTO_INJECTOR_ORDER = ["ydotool", "wtype", "xdotool"]


def select_injector(requested: str) -> tuple[Injector, list[str]]:
    names = AUTO_INJECTOR_ORDER if requested == "auto" else [requested]
    errors: list[str] = []

    for name in names:
        injector = INJECTOR_CLASSES[name]()
        probe = injector.probe()
        if probe.ok:
            return injector, errors
        errors.append(f"{name}: {probe.detail}")

    details = "\n".join(f"  - {item}" for item in errors)
    raise InjectorError(f"No usable text injector found.\n{details}")


def ydotool_needs_daemon(detail: str) -> bool:
    return "ydotoold is not reachable" in detail or "failed to connect socket" in detail


def wait_for_ydotool(timeout: float = 3.0) -> ProbeResult:
    injector = YdotoolInjector()
    deadline = time.time() + timeout
    last_probe = injector.probe()

    while time.time() < deadline:
        if last_probe.ok:
            return last_probe
        time.sleep(0.2)
        last_probe = injector.probe()

    return last_probe


def start_ydotool_daemon(*, prompt: bool) -> bool:
    daemon = YdotoolInjector.resolve_daemon()
    if not os.access(daemon, os.X_OK):
        print(f"ydotoold binary is missing: {daemon}", file=sys.stderr)
        return False

    argv = YdotoolInjector.daemon_argv()
    sudo_argv = ["sudo", "-b", *argv]
    command_text = " ".join(shlex.quote(part) for part in sudo_argv)

    if prompt:
        if not sys.stdin.isatty():
            print(f"Run this once from a real terminal:\n  {command_text}", file=sys.stderr)
            return False

        print("ydotoold is required for focused-window typing on this KDE Wayland session.")
        print(f"About to run:\n  {command_text}")
        answer = input("Start ydotoold now? [y/N] ").strip().lower()
        if answer not in {"y", "yes"}:
            return False

    result = subprocess.run(sudo_argv, check=False)
    if result.returncode != 0:
        print(f"Failed to start ydotoold with sudo, exit status {result.returncode}.", file=sys.stderr)
        return False

    probe = wait_for_ydotool()
    if probe.ok:
        print("ydotoold is running.")
        return True

    print(f"ydotoold start was attempted, but ydotool still is not ready: {probe.detail}", file=sys.stderr)
    return False


def maybe_setup_ydotool_for_normal_run(args: argparse.Namespace) -> None:
    if args.no_auto_setup or args.injector not in {"auto", "ydotool"}:
        return

    probe = YdotoolInjector().probe()
    if probe.ok or not ydotool_needs_daemon(probe.detail):
        return

    start_ydotool_daemon(prompt=True)


def process_alive(pid: int) -> bool:
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    return True


def request_stop() -> bool:
    if not PIDFILE.exists():
        return False

    try:
        pid = int(PIDFILE.read_text(encoding="utf-8").strip())
    except (OSError, ValueError):
        PIDFILE.unlink(missing_ok=True)
        return False

    PIDFILE.unlink(missing_ok=True)

    for _ in range(8):
        if not process_alive(pid):
            notify("Stopped")
            return True
        time.sleep(0.1)

    try:
        os.kill(pid, signal.SIGTERM)
    except ProcessLookupError:
        pass

    notify("Stopped")
    return True


def acquire_lock_or_toggle() -> bool:
    if PIDFILE.exists():
        try:
            pid = int(PIDFILE.read_text(encoding="utf-8").strip())
        except (OSError, ValueError):
            PIDFILE.unlink(missing_ok=True)
        else:
            if process_alive(pid):
                return not request_stop()
            PIDFILE.unlink(missing_ok=True)

    PIDFILE.write_text(str(os.getpid()), encoding="utf-8")
    return True


def release_lock() -> None:
    try:
        if PIDFILE.read_text(encoding="utf-8").strip() == str(os.getpid()):
            PIDFILE.unlink(missing_ok=True)
    except FileNotFoundError:
        pass
    except OSError:
        pass


class LiveDisplay:
    """Track live interim text and rewrite only the changed suffix."""

    def __init__(self, injector: Injector):
        self.injector = injector
        self.final_len = 0
        self.screen_text = ""
        self.lock = threading.Lock()

    def update(self, new_text: str, *, is_final: bool) -> None:
        with self.lock:
            old_text = self.screen_text

            diverge = self.final_len
            limit = min(len(old_text), len(new_text))
            while diverge < limit and old_text[diverge] == new_text[diverge]:
                diverge += 1

            backspaces = len(old_text) - diverge
            if backspaces:
                self.injector.backspace(backspaces)

            suffix = new_text[diverge:]
            if suffix:
                self.injector.type_text(suffix)

            self.screen_text = new_text

            if is_final:
                self.final_len = len(new_text)
                self.injector.type_text(" ")
                self.screen_text += " "
                self.final_len += 1


def audio_level_from_linear16(chunk: bytes) -> float:
    if not chunk:
        return 0.0

    samples = array.array("h")
    samples.frombytes(chunk)
    if sys.byteorder != "little":
        samples.byteswap()
    if not samples:
        return 0.0

    # Normalize RMS for speech visualization, not metering accuracy.
    mean_square = sum(sample * sample for sample in samples) / len(samples)
    rms = math.sqrt(mean_square) / 32768.0
    return max(0.0, min(1.0, rms * 9.0))


class MicrophoneStream:
    """Open a PyAudio microphone stream and yield linear16 chunks."""

    def __init__(self, rate: int = 16000, chunk_size: int = 1600, level_callback=None):
        self.rate = rate
        self.chunk_size = chunk_size
        self.level_callback = level_callback
        self._buff: queue.Queue[bytes | None] = queue.Queue()
        self._closed = True
        self._audio_interface = None
        self._audio_stream = None

    def __enter__(self) -> "MicrophoneStream":
        import pyaudio

        self._audio_interface = pyaudio.PyAudio()
        self._audio_stream = self._audio_interface.open(
            format=pyaudio.paInt16,
            channels=1,
            rate=self.rate,
            input=True,
            frames_per_buffer=self.chunk_size,
            stream_callback=self._fill_buffer,
        )
        self._closed = False
        return self

    def __exit__(self, exc_type, exc_val, exc_tb) -> None:
        self.close()

    def close(self) -> None:
        if self._closed:
            return

        self._closed = True
        self._buff.put(None)

        if self._audio_stream:
            self._audio_stream.stop_stream()
            self._audio_stream.close()

        if self._audio_interface:
            self._audio_interface.terminate()

    def _fill_buffer(self, in_data, frame_count, time_info, status_flags):
        import pyaudio

        self._buff.put(in_data)
        if self.level_callback:
            try:
                self.level_callback(audio_level_from_linear16(in_data))
            except Exception:
                pass
        return None, pyaudio.paContinue

    def generator(self):
        while not self._closed:
            chunk = self._buff.get()
            if chunk is None:
                return

            chunks = [chunk]
            while True:
                try:
                    chunk = self._buff.get(block=False)
                except queue.Empty:
                    break

                if chunk is None:
                    return
                chunks.append(chunk)

            yield b"".join(chunks)


def language_for_deepgram(lang: str) -> str:
    return "multi" if lang == "auto" else lang


def format_final_phrase(transcript: str) -> str:
    phrase = transcript.strip()
    if not phrase:
        return ""
    return phrase + " "


def build_deepgram_url(lang: str, model: str) -> str:
    params = [
        ("model", model),
        ("language", language_for_deepgram(lang)),
        ("punctuate", "true"),
        ("interim_results", "true"),
        ("encoding", "linear16"),
        ("sample_rate", "16000"),
        ("channels", "1"),
        ("smart_format", "true"),
        ("endpointing", "300"),
        ("dictation", "true"),
        ("utterance_end_ms", "1000"),
        ("vad_events", "true"),
        ("no_delay", "true"),
    ]

    keyterms = [
        "appwrite",
        "claude",
        "claude code",
        "docs",
        "mcp",
        "liviano",
        "bikecheck",
        "tmux",
        "dev server",
    ]
    params.extend(("keyterm", term) for term in keyterms)

    return "wss://api.deepgram.com/v1/listen?" + urlencode(params)


def run_streaming_recognition(args: argparse.Namespace, injector: Injector) -> str:
    websockets_sync_client = import_module_self_healing("websockets.sync.client")

    api_key, key_source = get_deepgram_api_key()
    if not api_key:
        raise RuntimeError(
            "No Deepgram API key found. Run `dg-easy setup`, set "
            "DEEPGRAM_API_KEY, or create ~/.config/deepgram-api-key."
        )

    print(f"Deepgram key: {key_source}")
    print(f"Text injector: {injector.name}")
    print("Listening. Run `dg-type` again to stop.")
    overlay_event(args, "listening")
    if args.no_overlay:
        notify(f"Listening with {injector.name}. Run dg-type again to stop.", timeout_ms=8000)

    global _global_stop_event
    stop_event = threading.Event()
    _global_stop_event = stop_event

    mic_stream: MicrophoneStream | None = None
    ws_holder: dict[str, object | None] = {"ws": None}
    last_activity = time.time()
    activity_lock = threading.Lock()
    final_text_parts: list[str] = []
    live_display = LiveDisplay(injector) if args.live else None
    live_final_text = ""

    def update_activity() -> None:
        nonlocal last_activity
        with activity_lock:
            last_activity = time.time()

    def stop_everything() -> None:
        stop_event.set()
        if mic_stream:
            mic_stream.close()

        ws = ws_holder.get("ws")
        if ws is not None:
            try:
                ws.close()
            except Exception:
                pass

    def watch_stop_conditions() -> None:
        while not stop_event.is_set():
            if not PIDFILE.exists():
                stop_everything()
                return

            if args.silence_timeout > 0:
                with activity_lock:
                    quiet_for = time.time() - last_activity
                if quiet_for >= args.silence_timeout:
                    print(f"Stopping after {args.silence_timeout:g}s of silence.")
                    stop_everything()
                    return

            time.sleep(0.1)

    threading.Thread(target=watch_stop_conditions, daemon=True).start()

    headers = {"Authorization": f"Token {api_key}"}
    ws_url = build_deepgram_url(args.lang, args.model)

    def update_overlay_level(level: float) -> None:
        overlay_event(args, "listening", level=level, force=False)

    try:
        with MicrophoneStream(level_callback=update_overlay_level) as stream:
            mic_stream = stream

            with websockets_sync_client.connect(
                ws_url,
                additional_headers=headers,
            ) as ws:
                ws_holder["ws"] = ws

                def send_audio() -> None:
                    for chunk in stream.generator():
                        if stop_event.is_set():
                            break
                        try:
                            ws.send(chunk)
                        except Exception:
                            break

                threading.Thread(target=send_audio, daemon=True).start()

                for msg in ws:
                    if stop_event.is_set():
                        break

                    try:
                        result = json.loads(msg)
                    except (TypeError, json.JSONDecodeError):
                        continue

                    msg_type = result.get("type")
                    if msg_type == "SpeechStarted":
                        overlay_event(args, "transcribing")
                        update_activity()
                        continue

                    if msg_type == "UtteranceEnd":
                        overlay_event(args, "listening")
                        update_activity()
                        continue

                    if msg_type != "Results":
                        continue

                    try:
                        transcript = result["channel"]["alternatives"][0]["transcript"]
                    except (KeyError, IndexError, TypeError):
                        continue

                    if not transcript:
                        continue

                    update_activity()
                    is_final = bool(result.get("is_final", False))

                    if live_display:
                        full_text = live_final_text + transcript.strip()
                        live_display.update(full_text, is_final=is_final)
                        overlay_event(
                            args,
                            "final" if is_final else "transcribing",
                            transcript.strip(),
                        )
                        log_event(
                            f"{'Final' if is_final else 'Interim'} phrase displayed: "
                            f"{len(transcript.strip())} chars"
                        )

                        if is_final:
                            phrase = format_final_phrase(transcript)
                            if phrase:
                                final_text_parts.append(phrase)
                                live_final_text = full_text + " "
                        continue

                    if not is_final:
                        continue

                    phrase = format_final_phrase(transcript)
                    if not phrase:
                        continue

                    log_event(f"Final phrase received: {len(phrase.strip())} chars")
                    overlay_event(args, "final", phrase.strip())
                    injector.type_text(phrase)
                    log_event(f"Injected phrase with {injector.name}")
                    final_text_parts.append(phrase)

    finally:
        overlay_event(args, "stopped")
        stop_everything()

    return "".join(final_text_parts).strip()


def run_check(args: argparse.Namespace) -> int:
    ok = True

    api_key, key_source = get_deepgram_api_key()
    if api_key:
        print(f"Deepgram key: found via {key_source}")
    else:
        print("Deepgram key: missing")
        ok = False

    for module_name in ("pyaudio", "websockets.sync.client"):
        try:
            module = import_module_self_healing(module_name)
        except Exception as exc:
            print(f"Python dependency {module_name}: missing ({exc})")
            ok = False
        else:
            module_path = getattr(module, "__file__", "")
            suffix = f" ({module_path})" if module_path else ""
            print(f"Python dependency {module_name}: ok{suffix}")

    try:
        injector, errors = select_injector(args.injector)
    except InjectorError as exc:
        print(str(exc))
        ok = False
    else:
        for item in errors:
            print(f"Skipped {item}")
        print(f"Text injector: {injector.name}")

    return 0 if ok else 1


def parse_args(argv: list[str]) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Deepgram microphone dictation into the focused window."
    )
    parser.add_argument(
        "--delay",
        type=float,
        default=0.0,
        help="Seconds to wait before opening the microphone.",
    )
    parser.add_argument(
        "--lang",
        default=DEFAULT_LANG,
        help="Deepgram language code, or auto for multilingual detection.",
    )
    parser.add_argument(
        "--model",
        default=DEFAULT_MODEL,
        help=f"Deepgram model to use. Default: {DEFAULT_MODEL}.",
    )
    parser.add_argument(
        "--silence-timeout",
        type=float,
        default=DEFAULT_SILENCE_TIMEOUT,
        help="Seconds of silence before stopping. Use 0 to disable.",
    )
    parser.add_argument(
        "--injector",
        choices=["auto", *AUTO_INJECTOR_ORDER],
        default="auto",
        help="Text injector to use. Default tries ydotool, then wtype, then xdotool.",
    )
    parser.add_argument(
        "--check",
        action="store_true",
        help="Check credentials, dependencies, and injector availability without dictating.",
    )
    parser.add_argument(
        "--setup-injector",
        action="store_true",
        help="Start ydotoold with sudo so focused-window typing works on Wayland.",
    )
    parser.add_argument(
        "--no-auto-setup",
        action="store_true",
        help="Do not offer to start ydotoold automatically during normal dictation.",
    )
    parser.add_argument(
        "--live",
        action="store_true",
        help="Type interim Deepgram results immediately and rewrite corrections.",
    )
    parser.add_argument(
        "--no-overlay",
        action="store_true",
        help="Use old desktop notifications instead of the animated overlay.",
    )
    return parser.parse_args(argv)


def main(argv: list[str] | None = None) -> int:
    args = parse_args(argv or sys.argv[1:])

    if args.setup_injector:
        return 0 if start_ydotool_daemon(prompt=False) else 1

    if args.check:
        return run_check(args)

    if not acquire_lock_or_toggle():
        print("Requested dg-type stop.")
        return 0

    def signal_handler(signum, frame) -> None:
        if _global_stop_event:
            _global_stop_event.set()
        release_lock()
        raise SystemExit(0)

    signal.signal(signal.SIGTERM, signal_handler)
    signal.signal(signal.SIGINT, signal_handler)

    try:
        maybe_setup_ydotool_for_normal_run(args)
        injector, errors = select_injector(args.injector)
        for item in errors:
            print(f"Skipped {item}")

        if args.delay > 0:
            print(f"Starting in {args.delay:g}s. Focus the target window now.")
            overlay_event(args, "listening", f"Starting in {args.delay:g}s")
            if args.no_overlay:
                notify(f"Starting in {args.delay:g}s. Focus the target window.", timeout_ms=2000)
            time.sleep(args.delay)

        run_streaming_recognition(args, injector)
        return 0
    except KeyboardInterrupt:
        return 0
    except Exception as exc:
        overlay_event(args, "error", str(exc)[:72])
        if args.no_overlay:
            notify(f"Error: {exc}", urgency="critical")
        print(f"dg-type: {exc}", file=sys.stderr)
        return 1
    finally:
        clear_notification()
        release_lock()


if __name__ == "__main__":
    raise SystemExit(main())
